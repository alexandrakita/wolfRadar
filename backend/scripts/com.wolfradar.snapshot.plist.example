<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  wolfRadar daily snapshot — macOS launchd agent

  Install:
    cp backend/scripts/com.wolfradar.snapshot.plist.example \
       ~/Library/LaunchAgents/com.wolfradar.snapshot.plist
    # Edit WorkingDirectory and ProgramArguments paths if needed
    launchctl load ~/Library/LaunchAgents/com.wolfradar.snapshot.plist

  Unload:
    launchctl unload ~/Library/LaunchAgents/com.wolfradar.snapshot.plist
-->
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.wolfradar.snapshot</string>

    <key>WorkingDirectory</key>
    <string>/Users/alexandrakita/wolfRadar/backend</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/bash</string>
      <string>/Users/alexandrakita/wolfRadar/backend/scripts/run-daily-snapshot.sh</string>
    </array>

    <!-- 06:00 America/New York, Mon–Fri (before US market open) -->
    <key>StartCalendarInterval</key>
    <array>
      <dict>
        <key>Weekday</key>
        <integer>1</integer>
        <key>Hour</key>
        <integer>6</integer>
        <key>Minute</key>
        <integer>0</integer>
      </dict>
      <dict>
        <key>Weekday</key>
        <integer>2</integer>
        <key>Hour</key>
        <integer>6</integer>
        <key>Minute</key>
        <integer>0</integer>
      </dict>
      <dict>
        <key>Weekday</key>
        <integer>3</integer>
        <key>Hour</key>
        <integer>6</integer>
        <key>Minute</key>
        <integer>0</integer>
      </dict>
      <dict>
        <key>Weekday</key>
        <integer>4</integer>
        <key>Hour</key>
        <integer>6</integer>
        <key>Minute</key>
        <integer>0</integer>
      </dict>
      <dict>
        <key>Weekday</key>
        <integer>5</integer>
        <key>Hour</key>
        <integer>6</integer>
        <key>Minute</key>
        <integer>0</integer>
      </dict>
    </array>

    <key>TimeZone</key>
    <string>America/New_York</string>

    <key>StandardOutPath</key>
    <string>/Users/alexandrakita/wolfRadar/backend/logs/launchd-snapshot.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/alexandrakita/wolfRadar/backend/logs/launchd-snapshot.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
      <key>PATH</key>
      <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
    </dict>
  </dict>
</plist>
