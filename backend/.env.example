# Port (default 3333)
PORT=3333

# Persistent data directory (Railway volume mount: /data)
# WOLF_DATA_DIR=/data

# Stock universe JSON (Docker default: bundled in image)
# STOCK_UNIVERSE_PATH=/app/backend/data/stock-universe-data.json

# Snapshot store: sqlite (local default) | redis (Vercel) | both (local build + Redis publish)
# SNAPSHOT_STORE=sqlite

# Upstash Redis (Vercel / live API reads)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Or Vercel KV naming:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Publish SQLite snapshot to Redis after build (also enabled when SNAPSHOT_STORE=both|redis)
# PUBLISH_REDIS=1

# Set to 1 to include 14-metric breakdown in GET /api/ratings/:symbol
# WOLF_RATING_DEBUG=1

# Or pass ?debug=your-secret-key when WOLF_RATING_DEBUG_KEY is set
# WOLF_RATING_DEBUG_KEY=
